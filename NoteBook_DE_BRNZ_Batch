# Normalize the incoming SolutionItemId to lowercase for case-insensitive comparison
key = PAR_PL_SolutionItemId.lower()

# Builds the path:
# LH_PROCESSING_BASE/ Tables/metadata/ PipelineParams_PL_RunNotebook.
# Reads the Delta table and filters by SolutionItemId (case-insensitive).
# limit(1).first() returns a single row or None.

# Read from the metadata Delta table
row = (spark.read.format("delta")
       .load(f"{LH_PROCESSING_BASE}/Tables/metadata/PipelineParams_PL_RunNotebook")                
       .where(F.lower(F.col("SolutionItemId")) == F.lit(key))         
       .limit(1)                                                   
       .first())                                          

# Fails fast if no row is found.
if not row:
    raise ValueError(f"Parameters not found for SolutionItemId={PAR_PL_SolutionItemId}")

# Retrieves the JSON string in NotebookParameters and validates it.
sol_Item = row["NotebookParameters"]

if not sol_Item:
    raise ValueError(f"NotebookParameters is null/empty for SolutionItemId={PAR_PL_SolutionItemId}")

try:
    file_info = json.loads(sol_Item)[0] if sol_Item.strip().startswith("[") else json.loads(sol_Item)
except Exception as e:
    raise ValueError(f"Failed to parse NotebookParameters JSON for {PAR_PL_SolutionItemId}: {e}")

# JSON parsing:
# Handles two forms of JSON:
# Array with one object: "[{...}]" → takes first element.
# Single object: "{...}" → use directly.
# Raises a detailed error if JSON parsing fails.
# Finally, it extracts the individual fields:

try:
